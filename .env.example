# Required model credentials
OPENAI_API_KEY=

# Model selection
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval behavior
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4
RAG_MIN_RELEVANCE=0.2

# Upload and optional public web search
MAX_UPLOAD_MB=20
WEB_SEARCH_RESULTS=5

# Override only when storing data outside the project directory
# DATA_DIR=/absolute/path/to/data
