# Required model credentials
GOOGLE_API_KEY=

# Model selection
GOOGLE_CHAT_MODEL=gemini-3.1-flash-lite
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# Embedding throughput and rate-limit handling
EMBEDDING_BATCH_SIZE=50
EMBEDDING_MAX_RETRIES=5
EMBEDDING_RETRY_DELAY=20

# Retrieval behavior
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4
RAG_MIN_RELEVANCE=0.2

# Upload and optional public web search
MAX_UPLOAD_MB=20
WEB_SEARCH_RESULTS=5

# Override only when storing data outside the project directory
# DATA_DIR=/absolute/path/to/data
